expression 'NSI Left Join NS + Left Anti NS Devol (Outros Canais)' =
		let
		    Fonte =
		        Odbc.Query("driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas", "#(lf)WITH base AS (#(lf)    SELECT#(lf)        nsi.id_nr_nf,#(lf)        nsi.id_empresa,#(lf)        nsi.id_cliente,#(lf)        nsi.data_emissao,#(lf)        nsi.id_produto,#(lf)        nsi.item,#(lf)        nsi.ipi_valor,#(lf)        nsi.qtde,#(lf)        nsi.valor_bruto,#(lf)        nsi.valor_liquido,#(lf)        nsi.custo_produto,#(lf)        nsi.id_nat_operacao_item,#(lf)        nsi.vr_frete,#(lf)        nsi.id_nota_saida,#(lf)        nsi.valor_total_liquido,#(lf)        nsi.id_vendedor,#(lf)        nsi.id_item_kit,#(lf)        nsi.item_original,#(lf)        nsi.custo_frete,#(lf)        nsi.sku,#(lf)        nsi.mlb,#(lf)        nsi.custo_formacao,#(lf)        nsi.codigos_kit,#(lf)        nsi.id_material,#(lf)        nsi.vr_acrescimo,#(lf)        nsi.vr_desconto_total#(lf)#(lf)    FROM sysemp.nota_saida_itens nsi#(lf)    INNER JOIN sysemp.nota_saida ns#(lf)        ON nsi.id_nota_saida = ns.id_nota_saida#(lf)#(lf)    WHERE#(lf)        nsi.data_emissao >= '2024-01-01'#(lf)#(lf)        AND nsi.id_nat_operacao_item IN (#(lf)            1,2,3,4,19,48,83,84,90,96,103,105,106,114,115,116,119,121#(lf)        )#(lf)#(lf)        AND nsi.id_nota_saida NOT IN (1604288,1609721,1520316)#(lf)#(lf)        AND (#(lf)            ns.id_atendimento IN (24,26,41)#(lf)            OR#(lf)            (ns.id_atendimento = 14 AND ns.id_vendedor = 520854)#(lf)        )#(lf)),#(lf)#(lf)rateio AS (#(lf)    SELECT#(lf)        base.*,#(lf)#(lf)        SUM(#(lf)            CASE#(lf)                WHEN base.id_produto IN (90315682,79020,90316150)#(lf)                THEN base.valor_bruto#(lf)                ELSE 0#(lf)            END#(lf)        ) OVER (PARTITION BY base.id_nota_saida) AS valor_transferencia_nota,#(lf)#(lf)        SUM(#(lf)            CASE#(lf)                WHEN id_produto NOT IN (90315682,79020,90316150)#(lf)                THEN base.valor_bruto#(lf)                ELSE 0#(lf)            END#(lf)        ) OVER (PARTITION BY base.id_nota_saida) AS base_rateio#(lf)#(lf)    FROM base#(lf)),#(lf)#(lf)consulta_esquerda AS (#(lf)    SELECT#(lf)        id_nr_nf,#(lf)        id_empresa,#(lf)        id_cliente,#(lf)        data_emissao,#(lf)        id_produto,#(lf)        item,#(lf)#(lf)        CAST(ipi_valor AS DECIMAL(18,2)) AS ipi_valor,#(lf)        qtde,#(lf)        CAST(custo_produto AS DECIMAL(18,2)) AS custo_produto,#(lf)#(lf)        id_nat_operacao_item,#(lf)        CAST(vr_frete AS DECIMAL(18,2)) AS vr_frete,#(lf)        id_nota_saida,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN valor_transferencia_nota = 0 THEN valor_total_liquido#(lf)                WHEN id_produto IN (90315682,79020) THEN 0#(lf)                ELSE valor_total_liquido +#(lf)                     (valor_total_liquido / NULLIF(base_rateio,0)) * valor_transferencia_nota#(lf)            END#(lf)        AS DECIMAL(18,2)) AS valor_total_liquido,#(lf)#(lf)        id_vendedor,#(lf)        id_item_kit,#(lf)        item_original,#(lf)#(lf)        CAST(custo_frete AS DECIMAL(18,2)) AS custo_frete,#(lf)#(lf)        sku,#(lf)        mlb,#(lf)#(lf)        CAST(custo_formacao AS DECIMAL(18,2)) AS custo_formacao,#(lf)#(lf)        codigos_kit,#(lf)        id_material,#(lf)#(lf)        CAST(vr_acrescimo AS DECIMAL(18,2)) AS vr_acrescimo,#(lf)        CAST(vr_desconto_total AS DECIMAL(18,2)) AS vr_desconto_total#(lf)#(lf)    FROM rateio#(lf)),#(lf)#(lf)consulta_direita AS (#(lf)    SELECT#(lf)        ns.id_nota_saida,#(lf)        ns.id_nat_operacao,#(lf)        ns.entrega_cidade,#(lf)        ns.entrega_uf,#(lf)        CAST(ns.total_nota_fiscal_liq AS DECIMAL(18,2)) AS total_nota_fiscal_liq,#(lf)        ns.id_transportadora,#(lf)        ns.data_pedido,#(lf)        ns.id_atendimento,#(lf)        ns.parceiro,#(lf)#(lf)        CASE#(lf)            WHEN ns.id_atendimento = 45#(lf)                THEN regexp_replace(ns.marketplace_pedido, '-[^-]*$', '')#(lf)            WHEN ns.id_atendimento = 5#(lf)                AND ns.data_pedido >= '2025-08-18'#(lf)                THEN regexp_replace('LU-' || ns.marketplace_pedido, '^LU-LU-', 'LU-')#(lf)            ELSE ns.marketplace_pedido#(lf)        END AS marketplace_pedido,#(lf)#(lf)        ns.fulfillment,#(lf)        ns.tipo_logistica#(lf)#(lf)    FROM sysemp.nota_saida ns#(lf)#(lf)    WHERE#(lf)        ns.tipo_documento = 'NF'#(lf)        AND ns.data_pedido >= '2024-01-01'#(lf)#(lf)        AND (#(lf)            (ns.id_empresa IN (1,5,7,12,13,14,15) AND ns.nfe_cstat = '100')#(lf)            OR#(lf)            (ns.id_empresa IN (7,5,13,14,15) AND (ns.nfe_cstat IS NULL OR ns.nfe_cstat = ''))#(lf)        )#(lf)#(lf)        AND ns.id_nat_operacao IN (#(lf)            1,2,3,4,19,48,83,84,90,96,103,105,106,114,115,116,119,121#(lf)        )#(lf)#(lf)        AND (#(lf)            ns.id_atendimento IN (24,26,41)#(lf)            OR#(lf)            (ns.id_atendimento = 14 AND ns.id_vendedor = 520854)#(lf)        )#(lf)),#(lf)#(lf)devolucoes AS (#(lf)    SELECT DISTINCT ref_numero_docfiscal#(lf)    FROM sysemp.nota_saida#(lf)    WHERE data_pedido >= '2024-01-01'#(lf)      AND ref_numero_docfiscal <> 0#(lf)      AND (ref_numero_docfiscal IS NOT NULL OR id_nota_saida_fatura <> '0')#(lf)      AND id_nat_operacao IN (#(lf)        8,11,12,29,32,42,44,47,59,60,72,75,76,87,88,89,91,93,104,123#(lf)      )#(lf))#(lf)#(lf)SELECT#(lf)    L.*,#(lf)    R.id_nat_operacao,#(lf)    R.entrega_cidade,#(lf)    R.entrega_uf,#(lf)    R.total_nota_fiscal_liq,#(lf)    R.id_transportadora,#(lf)    R.data_pedido,#(lf)    R.id_atendimento,#(lf)    R.parceiro,#(lf)    R.marketplace_pedido,#(lf)    R.fulfillment,#(lf)    R.tipo_logistica#(lf)#(lf)FROM consulta_esquerda L#(lf)LEFT JOIN consulta_direita R#(lf)    ON L.id_nota_saida = R.id_nota_saida#(lf)LEFT JOIN devolucoes D#(lf)    ON L.id_nr_nf = D.ref_numero_docfiscal#(lf)#(lf)WHERE D.ref_numero_docfiscal IS NULL#(lf)")
		in
		    Fonte
	lineageTag: 6aa1fb64-000b-45dc-b24a-5f61f5e85f81
	queryGroup: Sysemp

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

