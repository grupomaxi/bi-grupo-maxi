table 'Formula Agrupado - Item'
	lineageTag: 2e305409-0382-4594-8c0c-f1149382735a

	column item
		dataType: int64
		formatString: 0
		lineageTag: f5b23f9f-3e92-4e12-aa90-5a5e7c5ed0f3
		summarizeBy: sum
		sourceColumn: item

		annotation SummarizationSetBy = Automatic

	column 'Qtde Kits'
		dataType: int64
		formatString: 0
		lineageTag: b95fb86b-05c2-479e-bb0e-7b6f521cf6ea
		summarizeBy: sum
		sourceColumn: Qtde Kits

		annotation SummarizationSetBy = Automatic

	partition 'Formula Agrupado - Item' = m
		mode: import
		queryGroup: Sysemp
		source =
				let
				    Fonte =
				        Odbc.Query(
				            "driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas",
				            "
				SELECT
				    produto_formula.id_produto AS item,
				    COUNT(*) AS ""Qtde Kits""
				
				FROM sysemp.produto_formula
				
				GROUP BY produto_formula.id_produto
				"
				        )
				in
				    Fonte

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

