	column TemMeta
		formatString: 0
		lineageTag: 63af6410-da85-4390-b956-314ff3a10c4b
		summarizeBy: sum
		isNameInferred
		sourceColumn: [TemMeta]

		annotation SummarizationSetBy = Automatic

	partition Fato_Meta_IA = calculated
		mode: import
		source =
				
				FILTER(
				    ADDCOLUMNS(
				        CROSSJOIN(
				            SUMMARIZE(
				                produto,
				                produto[id_produto],
				                produto[nome_produto],
				                produto[Marca],
				                produto[Grupo],
				                produto[Subgrupo]
				            ),
				            SUMMARIZE(
				                dCalendario,
				                dCalendario[Date]
				            )
				        ),
				        "MetaMes",    CALCULATE(
				                          SUM(produto[Meta Faturamento]),
				                          FILTER(
				                              produto,
				                              produto[id_produto] = EARLIER(produto[id_produto])
				                          )
				                      ),
				        "MetaHoje",   [Sum Meta Até Ontem],
				        "MetaDiaria", CALCULATE(
				                          DIVIDE(
				                              SUM(produto[Meta Faturamento]),
				                              MAX(dCalendario[Ultimo dia do mês])
				                          ),
				                          FILTER(
				                              produto,
				                              produto[id_produto] = EARLIER(produto[id_produto])
				                          )
				                      ),
				        "TemMeta",    IF(
				                          CALCULATE(
				                              SUM(produto[Meta Faturamento]),
				                              FILTER(
				                                  produto,
				                                  produto[id_produto] = EARLIER(produto[id_produto])
				                              )
				                          ) > 0,
				                          1, 0
				                      )
				    ),
				    [TemMeta] = 1
				)

	annotation PBI_Id = 6308976a3753422cb5651a92c12be738

