	column 'id Nota e Produto'
		dataType: string
		lineageTag: e64e4ebb-e3e1-4c2d-8c5a-05e6ec1db698
		summarizeBy: none
		sourceColumn: id Nota e Produto

		annotation SummarizationSetBy = Automatic

	partition 'NSI Left Join NS + Left Anti NS Devol' = m
		mode: import
		queryGroup: Sysemp
		source =
				let
				    Fonte = Odbc.Query("driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas", "WITH base AS (#(lf)#(lf)    SELECT#(lf)        id_nr_nf,#(lf)        id_empresa,#(lf)        id_cliente,#(lf)        data_emissao,#(lf)        id_produto,#(lf)        item,#(lf)        ipi_valor,#(lf)        qtde,#(lf)        valor_bruto,#(lf)        valor_liquido,#(lf)        custo_produto,#(lf)        id_nat_operacao_item,#(lf)        vr_frete,#(lf)        id_nota_saida,#(lf)        valor_total_liquido,#(lf)        id_vendedor,#(lf)        id_item_kit,#(lf)        item_original,#(lf)        custo_frete,#(lf)        sku,#(lf)        mlb,#(lf)        custo_formacao,#(lf)        codigos_kit,#(lf)        id_material,#(lf)        vr_acrescimo,#(lf)        vr_desconto_total#(lf)    FROM sysemp.nota_saida_itens#(lf)    WHERE#(lf)        data_emissao >= '2024-01-01'#(lf)        AND id_nat_operacao_item IN (#(lf)            1,2,3,4,19,48,83,84,90,96,103,105,106,114,115,116,119,121#(lf)        )#(lf)        AND id_nota_saida NOT IN (1604288,1609721,1520316)#(lf)),#(lf)#(lf)rateio AS (#(lf)#(lf)    SELECT#(lf)        *,#(lf)#(lf)        SUM(#(lf)            CASE #(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN valor_bruto#(lf)                ELSE 0#(lf)            END#(lf)        ) OVER (PARTITION BY id_nota_saida) AS valor_transferencia_nota,#(lf)#(lf)        SUM(#(lf)            CASE #(lf)                WHEN id_produto NOT IN (90315682,79020,90316150)#(lf)                THEN valor_bruto#(lf)                ELSE 0#(lf)            END#(lf)        ) OVER (PARTITION BY id_nota_saida) AS base_rateio#(lf)#(lf)    FROM base#(lf)),#(lf)#(lf)consulta_esquerda AS (#(lf)#(lf)    SELECT#(lf)        id_nr_nf,#(lf)        id_empresa,#(lf)        id_cliente,#(lf)        data_emissao,#(lf)        id_produto,#(lf)#(lf)        id_nota_saida || '_' || id_produto#(lf)            AS ""id Nota e Produto"",#(lf)#(lf)        item,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE ipi_valor#(lf)            END#(lf)        AS DECIMAL(18,2)) AS ipi_valor,#(lf)#(lf)        qtde,#(lf)#(lf)        CAST(custo_produto AS DECIMAL(18,2)) AS custo_produto,#(lf)#(lf)        id_nat_operacao_item,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE vr_frete#(lf)            END#(lf)        AS DECIMAL(18,2)) AS vr_frete,#(lf)#(lf)        id_nota_saida,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                WHEN valor_transferencia_nota = 0#(lf)                THEN valor_total_liquido#(lf)                ELSE valor_total_liquido +#(lf)                    (valor_total_liquido / NULLIF(base_rateio,0)) * valor_transferencia_nota#(lf)            END#(lf)        AS DECIMAL(18,2)) AS valor_total_liquido,#(lf)#(lf)        id_vendedor,#(lf)        id_item_kit,#(lf)        item_original,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE custo_frete#(lf)            END#(lf)        AS DECIMAL(18,2)) AS custo_frete,#(lf)#(lf)        sku,#(lf)        mlb,#(lf)#(lf)        CAST(#(lf)            CASE #(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE custo_formacao#(lf)            END#(lf)        AS DECIMAL(18,2)) AS custo_formacao,#(lf)#(lf)        CAST(#(lf)            CASE #(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE COALESCE(custo_formacao,0) * COALESCE(qtde,0)#(lf)            END#(lf)        AS DECIMAL(18,2)) AS custo_formacao_linha,#(lf)#(lf)        codigos_kit,#(lf)        id_material,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE vr_acrescimo#(lf)            END#(lf)        AS DECIMAL(18,2)) AS vr_acrescimo,#(lf)#(lf)        CAST(#(lf)            CASE#(lf)                WHEN id_produto IN (90315682,79020,90316150)#(lf)                THEN 0#(lf)                ELSE vr_desconto_total#(lf)            END#(lf)        AS DECIMAL(18,2)) AS vr_desconto_total#(lf)#(lf)    FROM rateio#(lf)),#(lf)#(lf)consulta_direita AS (#(lf)#(lf)    SELECT#(lf)        ns.id_nota_saida,#(lf)        ns.id_nat_operacao,#(lf)        ns.entrega_cidade,#(lf)        ns.entrega_uf,#(lf)        CAST(ns.total_nota_fiscal_liq AS DECIMAL(18,2)) AS total_nota_fiscal_liq,#(lf)        ns.id_transportadora,#(lf)        ns.data_pedido,#(lf)        ns.id_atendimento,#(lf)        ns.parceiro,#(lf)#(lf)        CASE#(lf)            WHEN (#(lf)                ns.id_atendimento IN (24,26,41)#(lf)                OR (ns.id_atendimento = 14 AND ns.id_vendedor = 520854)#(lf)            )#(lf)                THEN ns.id_nota_saida::varchar#(lf)#(lf)            WHEN ns.id_atendimento = 45#(lf)                THEN regexp_replace(ns.marketplace_pedido, '-[^-]*$', '')#(lf)#(lf)            WHEN ns.id_atendimento = 5#(lf)                 AND ns.data_pedido >= '2025-08-18'#(lf)                THEN regexp_replace('LU-' || ns.marketplace_pedido, '^LU-LU-', 'LU-')#(lf)#(lf)            ELSE ns.marketplace_pedido#(lf)        END AS marketplace_pedido,#(lf)#(lf)        ns.fulfillment,#(lf)        ns.tipo_logistica,#(lf)#(lf)        a.nome_atendimento AS ""Canal""#(lf)#(lf)    FROM sysemp.nota_saida ns#(lf)#(lf)    LEFT JOIN sysemp.atendimento a#(lf)        ON ns.id_atendimento = a.id_sequencia#(lf)#(lf)    WHERE#(lf)        ns.tipo_documento = 'NF'#(lf)        AND ns.data_pedido >= '2024-01-01'#(lf)        AND (#(lf)            (ns.id_empresa IN (1,5,7,12,13,14,15) AND ns.nfe_cstat = '100')#(lf)            OR#(lf)            (ns.id_empresa IN (7,5,13,14,15) AND (ns.nfe_cstat IS NULL OR ns.nfe_cstat = ''))#(lf)        )#(lf)        AND ns.id_nat_operacao IN (#(lf)            1,2,3,4,19,48,83,84,90,96,103,105,106,114,115,116,119,121#(lf)        )#(lf)),#(lf)#(lf)devolucoes AS (#(lf)#(lf)    SELECT DISTINCT#(lf)        ref_numero_docfiscal#(lf)    FROM sysemp.nota_saida#(lf)    WHERE#(lf)        data_pedido >= '2024-01-01'#(lf)        AND ref_numero_docfiscal <> 0#(lf)        AND (ref_numero_docfiscal IS NOT NULL OR id_nota_saida_fatura <> '0')#(lf)        AND id_nat_operacao IN (#(lf)            8,11,12,29,32,42,44,47,59,60,72,75,76,87,88,89,91,93,104,123#(lf)        )#(lf))#(lf)#(lf)SELECT#(lf)    L.*,#(lf)    R.id_nat_operacao,#(lf)    R.entrega_cidade,#(lf)    R.entrega_uf,#(lf)    R.total_nota_fiscal_liq,#(lf)    R.id_transportadora,#(lf)    R.data_pedido,#(lf)    R.id_atendimento,#(lf)    R.parceiro,#(lf)    R.marketplace_pedido,#(lf)    R.fulfillment,#(lf)    R.tipo_logistica,#(lf)    R.""Canal""#(lf)#(lf)FROM consulta_esquerda L#(lf)#(lf)LEFT JOIN consulta_direita R#(lf)    ON L.id_nota_saida = R.id_nota_saida#(lf)#(lf)LEFT JOIN devolucoes D#(lf)    ON L.id_nr_nf = D.ref_numero_docfiscal#(lf)#(lf)WHERE D.ref_numero_docfiscal IS NULL")
				in
				    Fonte

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Exception

