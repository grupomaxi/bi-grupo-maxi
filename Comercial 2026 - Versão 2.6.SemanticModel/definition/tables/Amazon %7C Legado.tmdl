				    #"Valor Substituído" = Table.ReplaceValue(
				    Table.ReplaceValue(#"Cabeçalhos Promovidos", " GMT-8", "", Replacer.ReplaceText, {"data/hora"}),
				    " GMT-7", "", Replacer.ReplaceText, {"data/hora"}
				),
				    #"Tipo Alterado" = Table.TransformColumnTypes(#"Valor Substituído",{{"data/hora", type datetime}, {"total", Currency.Type}}),
				    #"Colunas Renomeadas" = Table.RenameColumns(#"Tipo Alterado",{{"id do pedido", "Pedido MKT"}, {"data/hora", "Data Pedido"}, {"total", "Repasse MKT"}}),
				    #"Colunas Removidas" = Table.RemoveColumns(#"Colunas Renomeadas",{"Data Pedido"}),
				    #"Linhas Agrupadas" = Table.Group(#"Colunas Removidas",{"Pedido MKT"},
				    {
				        {"Repasse MKT", each List.Sum([Repasse MKT]), type nullable number}
				    }
				),
				    #"Personalização Adicionada" = Table.AddColumn(#"Linhas Agrupadas", "Status MKT", each "Aprovado"),
				    #"Tipo Alterado1" = Table.TransformColumnTypes(#"Personalização Adicionada",{{"Status MKT", type text}, {"Repasse MKT", Currency.Type}}),
				    #"Personalização Adicionada1" = Table.AddColumn(#"Tipo Alterado1", "Canal", each "Amazon")
				in
				    #"Personalização Adicionada1"

