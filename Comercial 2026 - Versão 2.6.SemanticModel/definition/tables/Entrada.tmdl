	partition Entrada = m
		mode: import
		queryGroup: Sysemp
		source =
				let
				    Fonte = Odbc.Query("driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas", "SELECT#(lf)    id_produto, #(lf)    dt_entrada,#(lf)    qtde_entrada#(lf)FROM sysemp.entrada_nf_itens#(lf)WHERE dt_entrada > '2024-01-01'#(lf)")
				in
				    Fonte

	annotation PBI_NavigationStepName = Navegação

