	column 'Produto + Marca + Estoque' =
			
			produto[id_produto]
			& " | " &
			produto[nome_produto]
			& " | " &
			produto[Marca]
			& " | Estoque: "
			& FORMAT(
			    SUMX(
			        RELATEDTABLE(Estoque),
			        Estoque[estoque]
			    ),
			    "#,##0"
			)
		lineageTag: 30e54aaf-3400-4117-b56d-4aadc4af0a4b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition produto = m
		mode: import
		queryGroup: Sysemp
		source = ```
				let
				    Fonte =
				        Odbc.Query(
				            "driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas",
				
				"WITH produto_base AS (
				
				    SELECT 
				        p.id_produto,
				        p.codigo_auxiliar,
				        p.descricao,
				        p.cod_barra,
				        p.cod_fabrica,
				        p.id_secao,
				
				        CAST(NULLIF(REPLACE(p.produto_meta_visita, ',', '.'), '') AS DECIMAL(18,2)) AS produto_meta_visita,
				
				        p.id_marca,
				        p.id_categoria,
				        p.id_grupo,
				        p.id_subgrupo,
				        p.id_material,
				        p.dt_cadastro,
				        p.inativo,
				        p.disponivel,
				
				        p.produto_pma,  -- ✅ ADICIONADO
				
				        p.altura,
				        p.largura,
				        p.comprimento,
				        p.peso_bruto,
				        p.peso_liquido,
				
				        p.produto_estoque_full_magalu,
				        p.produto_estoque_full_meli,
				
				        p.produto_carteira_por_produto,
				        p.produto_carteira_marca,
				
				        p.produto_produto_meta_faturamento,
				        p.produto_produto_meta_margem,
				
				        p.produto_cod_shopee,
				        p.produto_codigo_meli,
				        p.produto_cod_amazon,
				
				        p.produto_cateogoria_magalu,
				        p.produto_cateogoria_shopee,
				
				        p.composicao_estoque,
				
				        ROUND(p.altura * p.largura * p.comprimento,2) AS volume_m3,
				
				        ROUND(
				            CASE 
				                WHEN p.peso_bruto < 30
				                    THEN p.altura * p.largura * p.comprimento * 167
				                ELSE p.altura * p.largura * p.comprimento * 300
				            END,2
				        ) AS peso_cubado
				
				    FROM sysemp.produto p
				    WHERE p.inativo = 'F'
				)
				
				SELECT 
				
				    p.id_produto,
				    p.codigo_auxiliar,
				
				    INITCAP(p.descricao) AS nome_produto,
				
				    p.cod_barra,
				    p.cod_fabrica,
				    p.id_secao,
				
				    p.produto_meta_visita AS ""Meta visitas"",
				
				    INITCAP(m.descricao) AS ""Marca"",
				    g.descricao AS ""Grupo"",
				    sb.descricao AS ""Subgrupo"",
				
				    SPLIT_PART(c.descricao,'/',1) AS ""Categoria.1"",
				    SPLIT_PART(c.descricao,'/',2) AS ""Categoria.2"",
				    SPLIT_PART(c.descricao,'/',3) AS ""Categoria.3"",
				    SPLIT_PART(c.descricao,'/',4) AS ""Categoria.4"",
				
				    c.descricao AS ""Categoria_Original"",
				
				    p.dt_cadastro,
				    p.inativo,
				    p.disponivel,
				
				    p.volume_m3,
				    p.peso_bruto,
				    p.peso_liquido,
				
				    p.comprimento,
				    p.largura,
				    p.altura,
				
				    p.peso_cubado,
				
				    GREATEST(p.peso_bruto,p.peso_cubado) AS peso_considerado,
				
				    CASE
				        WHEN GREATEST(p.peso_bruto,p.peso_cubado) <= 0.5 THEN 14.95
				        WHEN GREATEST(p.peso_bruto,p.peso_cubado) <= 1 THEN 17.95
				        WHEN GREATEST(p.peso_bruto,p.peso_cubado) <= 200 THEN 180.45
				        ELSE 187.95
				    END AS frete_simulado_magalu,
				
				    p.id_marca,
				
				    p.produto_pma AS ""PMA"",  -- ✅ ADICIONADO NO FINAL
				
				    p.produto_estoque_full_magalu,
				    p.produto_estoque_full_meli,
				
				    p.produto_carteira_por_produto,
				    p.produto_carteira_marca,
				
				    COALESCE(
				        NULLIF(p.produto_carteira_por_produto,''),
				        p.produto_carteira_marca
				    ) AS ""Carteira Definitiva"",
				
				    CAST(
				        NULLIF(REPLACE(p.produto_produto_meta_faturamento,',','.'),'')
				        AS DECIMAL(18,2)
				    ) AS ""Meta Faturamento"",
				
				    CAST(
				        NULLIF(REPLACE(REPLACE(p.produto_produto_meta_margem, '%', ''), ',', '.'), '')
				        AS DECIMAL(18,4)
				    ) / 100 AS produto_produto_meta_margem,
				
				    INITCAP(t.descricao) AS ""Tipo_Produto"",
				
				    p.produto_cod_shopee,
				    p.produto_codigo_meli,
				    p.produto_cod_amazon,
				
				    p.produto_cateogoria_magalu AS ""Categoria Magalu"",
				    p.produto_cateogoria_shopee AS ""Categoria Shopee""
				
				FROM produto_base p
				
				INNER JOIN sysemp.marca m 
				    ON p.id_marca = m.id_marca
				
				LEFT JOIN sysemp.categoria c 
				    ON p.id_categoria = c.id_categoria
				
				LEFT JOIN sysemp.grupo g 
				    ON p.id_grupo = g.id_grupo
				
				LEFT JOIN sysemp.subgrupo sb 
				    ON p.id_subgrupo = sb.id_subgrupo
				
				LEFT JOIN sysemp.tipo_produto t 
				    ON p.composicao_estoque = t.id_tp_produto"
				)
				in
				    Fonte
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

