	column Data
		dataType: dateTime
		formatString: Long Date
		lineageTag: 95b42c35-b39a-44b5-8e2d-ba432624fe08
		summarizeBy: none
		sourceColumn: Data

		variation Variation
			isDefault
			relationship: b709c93f-f201-476d-a80f-53effed0705a
			defaultHierarchy: LocalDateTable_0f5df81d-8552-4a4c-91ea-b70da998ba9d.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Investimento Rateado'
		dataType: decimal
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: b0a6feb4-cee6-4bd4-b15f-5b26d4002967
		summarizeBy: sum
		sourceColumn: Investimento Rateado

		annotation SummarizationSetBy = Automatic

