	column 'Repasse Rateado' =
			
			// -----------------------------------------------------------
			// MEDIDA: Repasse Rateado
			// Objetivo: distribuir (ratear) o valor de "Repasse MKT"
			// proporcionalmente ao valor bruto de cada item do pedido.
			// ----------------------------------------------------------
			
			    // -------------------------------------------------------
			    // Passo 1: Calcula o valor bruto total do pedido.
			    // Usa ALLEXCEPT para agrupar pelo identificador
			    // 'Pedido MKT Final' e ignorar outros filtros.
			    // Isso garante que o rateio será feito entre os itens
			    // do mesmo pedido, mesmo que haja filtros na página.
			    // -------------------------------------------------------
			    VAR TotalValorBruto =
			        CALCULATE (
			            SUM ( 'Base'[valor_total_liquido] ),
			            ALLEXCEPT ( 'Base', 'Base'[Pedido MKT Final] )
			        )
			
			    // -------------------------------------------------------
			    // Passo 2: Calcula a proporção individual do item.
			    // Utiliza DIVIDE para evitar erro de divisão por zero
			    // ou valores inválidos.
			    // Exemplo:
			    // Se o item é 30% do valor bruto total do pedido,
			    // sua proporção será 0,3.
			    // -------------------------------------------------------
			    VAR Proporcao =
			        DIVIDE ( 'Base'[valor_total_liquido], TotalValorBruto, 0 )
			
			    // -------------------------------------------------------
			    // Passo 3: Aplica o rateio proporcional.
			    // Multiplica a proporção do item pelo valor total
			    // de "Repasse MKT" daquele pedido.
			    // Assim, cada item recebe sua parte proporcional.
			    // -------------------------------------------------------
			    RETURN
			        Proporcao * 'Base'[Repasse MKT]
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: fcad70ef-abbf-469f-8a6d-37512338a0d0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	column Televendas? =
			
			
			IF(
			
			'Base'[id_atendimento] IN {41, 26, 24, 14},
			
			1,
			
			0
			
