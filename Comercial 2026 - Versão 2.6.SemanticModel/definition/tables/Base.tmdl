table Base
	lineageTag: 676a4474-59b9-493a-ac33-889432385c70

	measure 'Ranking Faturamento' =
			
			RANKX(
			    ALLSELECTED(Base[id_produto]),
			    [Faturamento],
			    ,
			    DESC,
			    DENSE
			)
		formatString: 0
		lineageTag: f989a990-8feb-4023-94da-8f770e05d93e

	measure 'Faturamento Total Filtrado' = ```
			
			CALCULATE(
			    [Faturamento],
			    ALLSELECTED(Base[id_produto])
			)
			
			
			```
		lineageTag: 4dca7070-2864-4e1e-8576-acf1aa61eb1b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Classificação ABC' = ```
			
			VAR CurrentProduct = SELECTEDVALUE(Base[id_produto])
			VAR CurrentRank = [Ranking Faturamento]
			VAR FaturamentoTotal = [Faturamento Total Filtrado]
			
			VAR FaturamentoAcumulado = 
			    CALCULATE(
			        [Faturamento],
			        FILTER(
			            ALLSELECTED(Base[id_produto]),
			            [Ranking Faturamento] <= CurrentRank
			        )
			    )
			
			VAR PercAcumulado = DIVIDE(FaturamentoAcumulado, FaturamentoTotal, 0)
			
			RETURN
			    SWITCH(
			        TRUE(),
			        PercAcumulado <= 0.8, "A",
			        PercAcumulado <= 0.95, "B",
			        "C"
			    )
			```
		lineageTag: 6cc4877d-b81d-460b-a704-bb7c0f1b7e19

	measure 'Quantidade A' = ```
			
			VAR TabelaProdutos = 
			    ADDCOLUMNS(
			        SUMMARIZE(Base, Base[id_produto]),
			        "Classif", [Classificação ABC]
			    )
			RETURN
			    COUNTROWS(FILTER(TabelaProdutos, [Classif] = "A"))
			```
		formatString: 0
		lineageTag: df16af6c-f7ba-42bb-a48d-1e35eb9eb324

	measure 'Quantidade B' = ```
			
			VAR TabelaProdutos = 
			    ADDCOLUMNS(
			        SUMMARIZE(Base, Base[id_produto]),
			        "Classif", [Classificação ABC]
			    )
			RETURN
			    COUNTROWS(FILTER(TabelaProdutos, [Classif] = "B"))	
			```
		formatString: 0
		lineageTag: a12a3d10-1c72-46bf-9628-e3c48ab0bc06

	measure 'Quantidade C' = ```
			
			VAR TabelaProdutos = 
			    ADDCOLUMNS(
			        SUMMARIZE(Base, Base[id_produto]),
			        "Classif", [Classificação ABC]
			    )
			RETURN
			    COUNTROWS(FILTER(TabelaProdutos, [Classif] = "C"))	
			```
		formatString: 0
		lineageTag: be8aed7b-8191-4988-865f-0ac30c69e582

