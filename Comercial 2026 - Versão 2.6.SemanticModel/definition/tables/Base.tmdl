		annotation SummarizationSetBy = Automatic

	column Meli? =
			
			SWITCH(
			    'Base'[id_atendimento],
			    20, 1, 7, 1, 32, 1, 27, 1, 8, 1,
			    0
			)
		formatString: 0
		lineageTag: 902ef94c-bf9a-498e-a55b-71d779190f15
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column tipo_entrega =
			
			VAR IdUltimaNota =
			    CALCULATE(
			        MAX('Base'[id_nota_saida]),
			        ALLEXCEPT('Base', 'Base'[Pedido MKT Final])
			    )
			VAR TransportadoraUltimaNota =
			    CALCULATE(
			        MAX('Base'[id_transportadora]),
			        FILTER(
			            ALLEXCEPT('Base', 'Base'[Pedido MKT Final]),
			            'Base'[id_nota_saida] = IdUltimaNota
			        )
			    )
			RETURN
			IF(
			    TransportadoraUltimaNota IN {6789, 1413, 9489, 310689, 0, 209106},
			    "ME2",
			    "ME1"
			)
		lineageTag: 555d9c18-3388-4fff-9a24-f7df0a1535b4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

