	column 'Canal Agrupado' =
			
			VAR vId = Base[id_atendimento]
			RETURN
			SWITCH(
			    TRUE(),
			    vId = 3, "Casas Bahia",
			    vId = 5, "Magalu",
			    vId = 6, "Dafiti",
			    vId IN {7, 8, 27, 32}, "Meli",
			    vId = 9, "Netshoes",
			    vId = 10, "Carrefour",
			    vId IN {12, 39}, "Madeira",
			    vId = 13, "Ri Happy",
			    vId = 14, "Padrão",
			    vId = 17, "Maxi Ferramentas",
			    vId IN {21, 37}, "Shopee",
			    vId = 23, "Webcontinenal",
			    vId = 24, "Olx",
			    vId = 25, "Manual",
			    vId = 26, "Balcão",
			    vId = 29, "Venda Interna",
			    vId IN {31, 34}, "Americanas",
			    vId IN {33, 35}, "Magalu",
			    vId = 36, "Leroy",
			    vId = 38, "Kabum",
			    vId = 40, "Aliexpress",
			    vId = 41, "Televendas",
			    vId = 42, "Tranfs",
			    vId IN {43, 44}, "Loja - Maxi Ferramentas",
			    vId = 47, "Loja - Cozilux",
			    vId IN {1, 45}, "Amazon",
			    vId = 46, "Leilão",
			    BLANK()
			)
		lineageTag: c12686d7-98a3-495a-8325-9a1fb1c577c0
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

