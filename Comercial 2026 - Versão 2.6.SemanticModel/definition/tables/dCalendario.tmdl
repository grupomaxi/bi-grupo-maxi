	column 'Mês - Ano'
		dataType: dateTime
		formatString: yyyy-mm
		lineageTag: d56bd21c-020d-410a-b9ab-49d555d0e969
		summarizeBy: none
		isNameInferred
		sourceColumn: [Mês - Ano]

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	partition dCalendario = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2024, 01, 01), DATE(2026, 12, 31)),
				    "Ano", YEAR([Date]),
				    "Trimestre", QUARTER([Date]) & "° Trimestre",
				    "Mês/Ano", UPPER(LEFT(FORMAT([Date], "mmm"), 1)) & MID(FORMAT([Date], "mmm"), 2, 2) & "/" & YEAR([Date]),
				    "Mês | Ano", FORMAT([Date], "mmmm | yyyy"),
				    "Mês - Ano", FORMAT([Date], "yyyy - mmmm "),
				    "Mês | Ano Ordem", YEAR([Date]) * 100 + MONTH([Date]),
				    "Contagem mes ano", DATEDIFF(DATE(2017, 1, 1), [Date], MONTH) + 1,
				    "Numero do Mês", MONTH([Date]),
				    "Nome do Mês", UPPER(LEFT(FORMAT([Date], "mmmm"), 1)) & MID(FORMAT([Date], "mmmm"), 2, LEN(FORMAT([Date], "mmmm")) - 1),
				    "Ultimo dia do mês", DAY(EOMONTH([Date], 0)),
				    "Primeiro dia do mês", DATE(YEAR([Date]), MONTH([Date]), 1),
				    "Dia", DAY([Date]),
				    "Nome do dia", UPPER(LEFT(FORMAT([Date], "dddd"), 1)) & MID(FORMAT([Date], "dddd"), 2, LEN(FORMAT([Date], "dddd")) - 1),
				    "Dia da semana como numero", WEEKDAY([Date]),
				    "Numero da semana do ano", WEEKNUM([Date]),
				    "Dia do ano acumulado", DATEDIFF(DATE(YEAR([Date]), 1, 1), [Date], DAY) + 1
				)
				
				
				
				```

	annotation PBI_Id = 12fd8477389940a8b66b16bf2c8fb113

