		annotation SummarizationSetBy = Automatic

	column 'Tipo Logistica'
		dataType: string
		lineageTag: c69648bc-f906-48b2-a8a7-a0177a3ec5ec
		summarizeBy: none
		sourceColumn: Tipo Logistica

		annotation SummarizationSetBy = Automatic

	partition Transportadoras = m
		mode: import
		queryGroup: Sysemp
		source =
				let
				    Fonte =
				        Odbc.Query(
				            "driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas",
				            "
				SELECT
				    cli.id_cliente,
				    cli.razsocial,
				    cli.fantasia,
				    cli.id_empresa,
				
				    CASE
				        WHEN cli.id_cliente IN (6789,1413,9489,310689,0,209106)
				            THEN 'Logistica_2'
				        ELSE 'Logistica_1'
				    END AS ""Tipo Logistica""
				
				FROM sysemp.cliente cli
				
				WHERE cli.transportadora = 'T'
				"
				        )
				in
				    Fonte

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

