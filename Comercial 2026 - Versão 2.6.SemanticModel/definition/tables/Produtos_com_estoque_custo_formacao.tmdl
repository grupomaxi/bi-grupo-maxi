	column 'Custo Total'
		dataType: double
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: ce671d28-8642-4999-b135-44965739ae55
		summarizeBy: sum
		sourceColumn: Custo Total

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	partition Produtos_com_estoque_custo_formacao = m
		mode: import
		queryGroup: Sysemp
		source = ```
				let
				    Fonte =
				        Odbc.Query(
				            "driver={PostgreSQL ANSI(x64)};server=maxiferramentas.fabricadecodigos.com.br;port=5433;database=maxiferramentas",
				            "
				SELECT 
				    pi.id_produto AS ""Código Interno"",
				    SUM(pi.estoque) AS ""Qtde Disponível"",
				    MAX(pe.custo_formacao) AS custo_formacao,
				    SUM(pi.estoque) * MAX(pe.custo_formacao) AS ""Custo Total""
				FROM sysemp.produto_inventario pi
				JOIN sysemp.produto_estoque pe
				    ON pe.id_produto = pi.id_produto
				WHERE pi.id_empresa = 1
				GROUP BY pi.id_produto
				HAVING SUM(pi.estoque) > 0
				"
				        )
				in
				    Fonte
				```

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

