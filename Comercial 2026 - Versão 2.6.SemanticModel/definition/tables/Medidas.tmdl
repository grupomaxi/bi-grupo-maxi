			    vPercentual * vFaturamentoFiltrado
			)
			```
		lineageTag: 55304d67-d4ad-446e-a480-f6fa5ce08dd0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Repasse Considerado' =
			
			SUMX(
			    SUMMARIZE(
			        Base,
			        Base[id_produto],
			        Base[id_nota_saida],
			        Base[id_atendimento],
			        Base[item]
			    ),
			    CALCULATE(
			        VAR idSequencia = MAX(Base[id_atendimento])
			        VAR DataVenda = MAX(Base[data_emissao])
			
			        VAR FaturamentoAtual = [Faturamento]
			        VAR FaturamentoSemFrete = COALESCE([Faturamento sem frete], 0)
			
			        VAR FreteOriginal = COALESCE([Frete Maxi], 0)
			
			        VAR Frete = FreteOriginal
			
			        VAR RepasseRateado = COALESCE([Repasse Rateado $], 0)
			
			        VAR Canal = MAX(Base[id_atendimento])
			        VAR EhMeli = Canal IN {20, 7, 32, 27, 8}
			
			        VAR idtransportadora = MAX(Base[id_transportadora])
			
			        VAR EhME1 =
			            NOT (
			                idtransportadora IN {310689, 626883, 210148, 197034, 500723, 1413, 391010, 209106, 6789, 9489, 209106, 209105,0}
			            )
			
			        VAR EhME2 =
			            idtransportadora IN {310689, 626883, 210148, 197034, 500723, 1413, 391010, 209106, 6789, 9489, 209106, 209105,0}
			
			        VAR Bonus2Porcento =
			            IF(
			                idSequencia IN {1, 15, 45}
			                    && DataVenda >= DATE(2026, 3, 1),
			                FaturamentoAtual * 0.02,
			                0
			            )
			
			        VAR Resultado =
			            RepasseRateado
			                - IF(
			                    EhMeli && EhME1,
			                    IF(
			                        RepasseRateado >= FaturamentoSemFrete * 0.95,
			                        Frete,
			                        0
			                    ),
			                    IF(EhME2, 0, Frete)
			                )
			
			        VAR Afiliado = [Faturamento]
			
			        RETURN
			            Resultado + Bonus2Porcento
			    )
			)
		lineageTag: 03f95d81-c519-4200-9be7-2b3963f71c2c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Status Repasse (1/0)' = VAR LinhasOK = SUMX( Base, VAR idtransportadora = Base[id_transportadora] VAR EhME1 = NOT ( idtransportadora IN {6789, 1413, 9489, 310689, 0, 209106} ) VAR EhME2 = idtransportadora IN {6789, 1413, 9489, 310689, 0, 209106} VAR RepasseBruto = [Repasse Rateado $] VAR RepasseLiquido = [Repasse Considerado] VAR Frete = [Frete Maxi] RETURN IF( (EhME2 && RepasseLiquido = RepasseBruto) || (EhME1 && (RepasseBruto - Frete) = RepasseLiquido), 1, 0 ) ) VAR TotalLinhas = COUNTROWS(Base) RETURN DIVIDE(LinhasOK, TotalLinhas)
		lineageTag: e363d20a-bf79-4cc2-ae14-bcce65f4eab5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Considerou Frete?' =
			
			SUMX(
			    SUMMARIZE(
			        Base,
			        Base[id_produto],
			        Base[id_nota_saida],
			        Base[id_atendimento],
			        Base[item]
			    ),
			    CALCULATE(
			        VAR idSequencia = MAX(Base[id_atendimento])
			        VAR DataVenda = MAX(Base[data_emissao])
			
			        VAR FaturamentoAtual = [Faturamento]
			        VAR FaturamentoSemFrete = COALESCE([Faturamento sem frete], 0)
			
			        VAR FreteOriginal = COALESCE([Frete Maxi], 0)
			
			        VAR Frete =
			            IF(
			                idSequencia IN {21, 37},
			                0,
			                FreteOriginal
			            )
			
			        VAR RepasseRateado = COALESCE([Repasse Rateado $], 0)
			
			        VAR Canal = MAX(Base[id_atendimento])
			        VAR EhMeli = Canal IN {20, 7, 32, 27, 8}
			
			        VAR idtransportadora = MAX(Base[id_transportadora])
			
			        VAR EhME1 =
			            NOT (
			                idtransportadora IN {310689, 626883, 210148, 197034, 500723, 1413, 391010, 209106, 6789, 9489, 209106, 209105,0}
			            )
			
			        VAR EhME2 =
			            idtransportadora IN {310689, 626883, 210148, 197034, 500723, 1413, 391010, 209106, 6789, 9489, 209106, 209105,0}
			
			        VAR Bonus2Porcento =
			            IF(
			                idSequencia IN {1, 15, 45}
			                    && DataVenda >= DATE(2026, 3, 1),
			                FaturamentoAtual * 0.02,
			                0
			            )
			
			        VAR Resultado =
			            IF(
			                    EhMeli && EhME1,
			                    IF(
			                        RepasseRateado >= FaturamentoSemFrete * 0.90,
			                        Frete,
			                        0
			                    ),
			                    IF(EhME2, 0, Frete)
			                )
			
			        VAR Afiliado = [Faturamento]
			
			        RETURN
			            Resultado
			    )
			)
		lineageTag: 8b97fa68-8463-4200-9016-b60be7878abe

