	measure 'tipo_entrega 2' =
			
			VAR UltimaNota =
			    CALCULATE(
			        MAX('Base'[id_nota_saida]),
			        ALLEXCEPT('Produto', 'Produto'[id_produto])
			    )
			
			VAR Transportadora =
			    CALCULATE(
			        MAX('Base'[id_transportadora]),
			        'Base'[id_nota_saida] = UltimaNota
			    )
			
			RETURN
			IF(
			    Transportadora IN {6789,1413,9489,310689,0,209106},
			    "ME2",
