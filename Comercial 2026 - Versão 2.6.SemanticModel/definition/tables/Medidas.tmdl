	measure '% Meta Batida' =
			
			VAR QuantidadeA =
			    SUMX(
			        'produto',
			        IF(
			            NOT ISBLANK([Meta_produto]) &&
			            [Meta_produto] > 0 &&
			            [GAP] >= 0,
			            1,
			            0
			        )
			    )
			
			VAR QuantidadeB =
			    SUMX(
			        'produto',
			        IF(
			            NOT ISBLANK([Meta_produto]) &&
			            [Meta_produto] > 0,
			            1,
			            0
			        )
			    )
			
			RETURN
			    DIVIDE(QuantidadeA, QuantidadeB, 0)
