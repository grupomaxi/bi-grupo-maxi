	measure Faturamento = ```
			
			VAR vLiquido =
			    SUM ( Base[valor_total_liquido] )
			
			VAR vDesconto =
			    SUM ( Base[vr_desconto_total] )
			
			VAR vAcrescimo =
			    SUM ( Base[vr_acrescimo] )
			
			VAR vFrete =
			    SUM ( Base[vr_frete] )
			
			VAR vIPI =
			    SUM ( Base[ipi_valor] )
			
			RETURN
			    vLiquido
			    - vDesconto
			    + vAcrescimo
			    + vFrete
			    + vIPI
			
			```
