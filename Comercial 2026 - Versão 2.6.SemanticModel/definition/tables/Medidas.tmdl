	measure 'Forecast Pedidos Shopify' =
			
			VAR Hoje = TODAY()
			VAR InicioMesAtual = DATE(YEAR(Hoje), MONTH(Hoje), 1)
			VAR UltimoDiaMesAtual = EOMONTH(Hoje, 0)
			VAR UltimoDiaMesAnterior = EOMONTH(Hoje, -1)
			VAR Ontem = Hoje - 1
			
			VAR DiasPassados = MAX(1, DAY(Ontem))
			VAR DiasNoMes = DAY(UltimoDiaMesAtual)
			
			// existe mês atual dentro do filtro?
			VAR TemMesAtualNoFiltro =
			    CALCULATE(
			        COUNTROWS(dCalendario),
			        KEEPFILTERS(
			            dCalendario[Date] >= InicioMesAtual
			                && dCalendario[Date] <= UltimoDiaMesAtual
			        )
			    ) > 0
			
			// (1) Realizado até o mês anterior
			VAR NotasAteMesAnterior_NoFiltro =
			    CALCULATE(
			        DISTINCTCOUNT('Base'[id_nota_saida]),
			        'Atendimento'[id_sequencia] IN {44, 47},
			        KEEPFILTERS(dCalendario[Date] <= UltimoDiaMesAnterior)
			    )
			
			// (2) Notas do mês atual até ontem
			VAR NotasMesAtualAteOntem_NoFiltro =
			    CALCULATE(
			        DISTINCTCOUNT('Base'[id_nota_saida]),
			        'Atendimento'[id_sequencia] IN {44, 47},
			        KEEPFILTERS(
			            dCalendario[Date] >= InicioMesAtual
			                && dCalendario[Date] <= Ontem
			        )
			    )
			
			VAR ForecastNotasMesAtual =
			    DIVIDE(NotasMesAtualAteOntem_NoFiltro, DiasPassados) * DiasNoMes
			
			RETURN
			NotasAteMesAnterior_NoFiltro
			    + IF(TemMesAtualNoFiltro, ForecastNotasMesAtual, 0)
		lineageTag: ec491fe1-96f6-4bbf-a94b-fb92b46085a9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

