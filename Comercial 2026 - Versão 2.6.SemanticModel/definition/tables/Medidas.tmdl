	measure 'Score 1D' =
			
			VAR Atual =
			    COALESCE([Fat Ontem], 0)
			
			VAR Anterior =
			    COALESCE([Fat Anteontem], 0)
			
			RETURN
			SWITCH(
			    TRUE(),
			    Atual = 0 && Anterior = 0, 1,
			    Atual > 0 && Anterior = 0, 2,
			    Atual = 0 && Anterior > 0, 0,
			    DIVIDE(Atual, Anterior)
			)
