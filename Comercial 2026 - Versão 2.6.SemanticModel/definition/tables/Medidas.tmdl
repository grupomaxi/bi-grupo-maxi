			        CALCULATE(
			            [Faturamento] * 0.006,
			         'Atendimento'[id_sequencia] IN {44, 47}
			 )
			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 0367e5f0-c1c9-4c05-9933-34c4bd05cbd4

