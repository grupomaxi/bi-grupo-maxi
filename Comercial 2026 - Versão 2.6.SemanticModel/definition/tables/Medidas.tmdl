	measure Forecast =
			
			VAR Hoje = TODAY()
			VAR InicioMesAtual = DATE(YEAR(Hoje), MONTH(Hoje), 1)
			VAR UltimoDiaMesAtual = EOMONTH(Hoje, 0)
			VAR UltimoDiaMesAnterior = EOMONTH(Hoje, -1)
			VAR Ontem = Hoje - 1
			
			VAR DiasPassados = MAX(1, DAY(Ontem))
			VAR DiasNoMes = DAY(UltimoDiaMesAtual)
			
			// checa se o filtro atual inclui alguma data do mês atual
			VAR TemMesAtualNoFiltro =
			    CALCULATE(
			        COUNTROWS(dCalendario),
			        KEEPFILTERS(
			            dCalendario[Date] >= InicioMesAtual
			                && dCalendario[Date] <= UltimoDiaMesAtual
			        )
			    ) > 0
			
			// (1) Realizado até o mês anterior, respeitando filtro do relatório
			VAR RealizadoAteMesAnterior_NoFiltro =
			    CALCULATE(
			        [Faturamento],
			        KEEPFILTERS(dCalendario[Date] <= UltimoDiaMesAnterior)
			    )
			
			// (2) Faturamento do mês atual até ontem, respeitando filtro do relatório
			VAR FaturamentoMesAtualAteOntem_NoFiltro =
			    CALCULATE(
			        [Faturamento],
			        KEEPFILTERS(
			            dCalendario[Date] >= InicioMesAtual
			                && dCalendario[Date] <= Ontem
			        )
			    )
			
			VAR ForecastMesAtual =
			    DIVIDE(FaturamentoMesAtualAteOntem_NoFiltro, DiasPassados) * DiasNoMes
			
			RETURN
			RealizadoAteMesAnterior_NoFiltro + IF(TemMesAtualNoFiltro, ForecastMesAtual, 0)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 053f6a4a-ef73-4c6f-9584-9f4def5f6d48

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

