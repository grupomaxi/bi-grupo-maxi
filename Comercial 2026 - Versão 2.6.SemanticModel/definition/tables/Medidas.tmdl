			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 2fec3c4e-ba02-4927-949a-92cb8dbbce73

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Custo Fixo Variável Shopify' =
			
			VAR Hoje = TODAY()
			VAR InicioMesAtual = DATE(YEAR(Hoje), MONTH(Hoje), 1)
			VAR Ontem = Hoje - 1
			
			VAR DiasPassados = MAX(1, DAY(Ontem))
			VAR DiasNoMes = DAY(EOMONTH(Hoje, 0))
			
			VAR NotasAteOntem =
			    CALCULATE(
			        COUNTROWS('Base'),
			        'Atendimento'[id_sequencia] IN {44, 47},
			        FILTER(
			            ALL(dCalendario[Date]),
			            dCalendario[Date] >= InicioMesAtual &&
			            dCalendario[Date] <= Ontem
			        )
			    )
			
			RETURN
			DIVIDE(NotasAteOntem, DiasPassados) * DiasNoMes
		lineageTag: d817a199-0e97-4e35-84d3-43268436377f

