	measure 'Margem R$' =
			
			SUMX(
			    SUMMARIZE(
			        Base,
			        Base[id_produto],
			        Base[id_nota_saida],
			        Base[id_atendimento],
			        Base[item]
			    ),
			    CALCULATE(
			        VAR FaturamentoAtual = [Faturamento]
			        VAR CustoFormacao = [Custo Formação Total]
			        VAR ImpostoTotal = [Imposto Geral] + [R$ IPI]
			        VAR OverFrete = [Over Frete]
			
			        VAR idSequencia = MAX(Atendimento[id_sequencia])
			        VAR DataVenda = MAX(Base[data_emissao])
			
			        VAR FreteOriginal = COALESCE([Frete Maxi], 0)
			
			        VAR Frete =
			            IF(
			                idSequencia = 21 || idSequencia = 37,
			                0,
			                FreteOriginal
			            )
			
			        VAR CustoMarketing = COALESCE([Ads Rateado MKT 2], 0)
			        VAR CustoLoja = COALESCE([Ads Rateado Loja], 0)
			        VAR CustoShopify = COALESCE([Shopify Variável], 0)
			        VAR AquisicaoShopify = COALESCE([Aquisição Shopify e Televendas], 0)
			        VAR RepasseRateado = COALESCE([Repasse Rateado $], 0)
			        VAR FaturamentoSemFrete = COALESCE([Faturamento sem frete], 0)
			
			        VAR Canal = MAX(Base[id_atendimento])
			        VAR EhMeli = Canal IN { 20, 7, 32, 27, 8 }
			        VAR EhShopee = Canal IN {948,37,21}
			        VAR EhTelevendas = Canal IN { 41, 26, 24, 14 }
			
			        VAR idtransportadora = MAX(Base[id_transportadora])
			
			        VAR EhME1 =
			            NOT (
			                idtransportadora IN {310689, 626883, 210148, 197034, 500723, 1413, 391010, 209106, 6789, 9489, 209106, 209105,0}
			            )
			
			        VAR EhME2 =
			            idtransportadora IN {310689, 626883, 210148, 197034, 500723, 1413, 391010, 209106, 6789, 9489, 209106, 209105,0}
			
			        // Handicap Amazon - NOVA REGRA 2%
			        VAR Bonus2Porcento =
			            IF(
			                idSequencia IN {1, 15, 45}
			                    && DataVenda >= DATE(2026, 3, 1),
			                FaturamentoAtual * 0.02,
			                0
			            )
			
			        VAR Resultado =
			            SWITCH(
			                TRUE(),
			
			                EhTelevendas,
			                    FaturamentoAtual
			                        - CustoFormacao
			                        - ImpostoTotal
			                        - Frete
			                        - (FaturamentoAtual * 0.06),
			
			                RepasseRateado
			                    - ImpostoTotal
			                    - CustoFormacao
			                    - IF(
			                        EhMeli && EhME1,
			                        IF(RepasseRateado >= FaturamentoSemFrete * 0.95, Frete, 0),
			                        IF(EhME2, 0, Frete)
			                    )
			                    - CustoMarketing
			                    - CustoLoja
			                    - CustoShopify
			                    - AquisicaoShopify
			                    + IF(
			                        EhME1,
			                        OverFrete,
			                        0
			                    )
			            )
			
			        RETURN
			            Resultado + Bonus2Porcento
			    )
			)
		lineageTag: a321b1c3-633a-4743-b02c-fdea1003973a

