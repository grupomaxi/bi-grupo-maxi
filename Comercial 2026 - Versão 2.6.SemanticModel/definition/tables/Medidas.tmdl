		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Meta_produto = ```
			
			// ----------------------------------------------------------------------
			// MEDIDA: Meta_produto
			// Objetivo: calcular quanto da meta mensal de um produto já deveria
			// ter sido atingido até o dia atual (meta proporcional).
			//
			// A lógica divide a meta do mês pelo número total de dias do mês e
			// multiplica pelo número de dias já passados.
			// ----------------------------------------------------------------------
			
			VAR produt =
			    // ------------------------------------------------------------
			    // Soma da meta definida para o produto.
			    // Esta meta é mensal e está na tabela 'produto'.
			    // ------------------------------------------------------------
			    SUM ( produto[Meta Faturamento] )
			
			VAR dia_atual =
			    // ------------------------------------------------------------
			    // Número de dias decorridos no mês.
			    // Usamos DAY(TODAY()) - 1 porque:
			    // - DAY(TODAY()) → retorna o dia corrente
			    // - menos 1 → computa apenas dias COMPLETOS já passados
			    //
			    // Exemplo:
			    // Se hoje é dia 10 → consideramos 9 dias completos.
			    // ------------------------------------------------------------
			    DAY ( TODAY() ) - 1
			
			RETURN
			    // ------------------------------------------------------------
			    // Meta proporcional até o dia atual:
			    //
			    // (meta total * dias passados) / número total de dias do mês
			    //
			    // DIVIDE evita erros (ex.: divisão por zero).
			    // MAX(dCalendario[Ultimo dia do mês]) retorna quantos dias
			    // tem o mês filtrado (28, 30, 31).
			    // ------------------------------------------------------------
			    DIVIDE (
			        produt * dia_atual,
			        MAX ( dCalendario[Ultimo dia do mês] )
			    )
			
			```
		lineageTag: a667c805-aeca-4d66-89e5-c103b517149c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

