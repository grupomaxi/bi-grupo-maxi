	measure 'Over Frete Ajustado' =
			
			SUMX(
			    SUMMARIZE(
			        Base,
			        Base[id_produto],
			        Base[id_nota_saida],
			        Base[id_atendimento],
			        Base[item]
			    ),
			    CALCULATE(
