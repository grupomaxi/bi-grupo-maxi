	measure 'Imposto Geral' =
			
			VAR Imposto_Log1 =
			    CALCULATE (
			        [Faturamento sem frete],
			        FILTER (
			            'Base',
			            'Base'[id_transportadora] = 0
			                || RELATED ( 'Transportadoras'[tipo logistica] ) = "Logistica_1"
			        )
			    )
			
			VAR Imposto_Log2 =
			    CALCULATE (
			        [Faturamento],
			        FILTER (
			            'Base',
			            'Base'[id_transportadora] <> 0
			                && RELATED ( 'Transportadoras'[tipo logistica] ) = "Logistica_2"
			        )
			    )
			
			RETURN
			    ( Imposto_Log1 + Imposto_Log2 ) * 0.1725
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: c5621383-6662-4b5c-ac90-ebee2652c164

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Faturamento sem frete' = ```
			
			SUM(Base[valor_total_liquido]) 
			- SUM(Base[vr_desconto_total]) 
			+ SUM(Base[vr_acrescimo])
			+ SUM(Base[ipi_valor])
			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: bab2f748-dfab-4018-9138-2a90743ab05e

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Imposto Total' =
			VAR Faturamento_Log1 =
			    CALCULATE(
			        [Faturamento sem frete],
			        'Transportadoras'[tipo logistica] = "Logistica_1"
			    )
			VAR Faturamento_Log2 =
			    CALCULATE(
			        [Faturamento],
			        'Transportadoras'[tipo logistica] = "Logistica_2"
			    )
			VAR Imposto_Geral =
			    (Faturamento_Log1 + Faturamento_Log2) * 0.1725
			VAR Faturamento_Total =
			    Faturamento_Log1 + Faturamento_Log2
			RETURN
			    DIVIDE(Imposto_Geral, Faturamento_Total, 0)
		formatString: 0.0%;-0.0%;0.0%
